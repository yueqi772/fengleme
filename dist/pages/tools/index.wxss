.page{background:#f0f0f0;min-height:100vh;padding:16rpx}.page-title{color:#333;display:block;font-size:16rpx;font-weight:700;margin-bottom:4rpx}.page-desc{color:#aaa;display:block;font-size:12rpx;margin-bottom:16rpx}.scenario-item{align-items:center;background:#fff;border-radius:16rpx;display:flex;justify-content:space-between;margin-bottom:10rpx;padding:16rpx}.scenario-left{align-items:flex-start;display:flex;flex:1;gap:12rpx}.scenario-icon{flex-shrink:0;font-size:32rpx;line-height:1}.scenario-info{flex:1}.scenario-title{color:#333;display:block;font-size:14rpx;font-weight:600;margin-bottom:4rpx}.scenario-intro{color:#888;display:block;font-size:12rpx;line-height:1.5;margin-bottom:6rpx}.scenario-diff{display:flex;gap:2rpx}.star{color:#ddd;font-size:12rpx}.star.active{color:#f59e0b}.arrow{color:#ddd;flex-shrink:0;font-size:20rpx}.script-item{align-items:center;background:#fff;border-radius:16rpx;display:flex;gap:12rpx;margin-bottom:8rpx;padding:14rpx 16rpx}.script-icon{flex-shrink:0;font-size:24rpx}.script-info{flex:1}.script-title{color:#333;display:block;font-size:14rpx;font-weight:600;margin-bottom:2rpx}.script-desc{color:#888;display:block;font-size:12rpx;line-height:1.4}.script-tag{background:#f5f5f5;border-radius:9999rpx;flex-shrink:0;padding:2rpx 8rpx}.tag-text{color:#666;font-size:11rpx}
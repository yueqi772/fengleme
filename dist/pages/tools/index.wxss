.page{background:#f0f0f0;box-sizing:border-box;min-height:100vh;padding:32rpx}.page-title{color:#333;display:block;font-size:32rpx;font-weight:700;margin-bottom:8rpx}.page-desc{color:#aaa;display:block;font-size:24rpx;margin-bottom:32rpx}.scenario-item{align-items:center;background:#fff;border-radius:32rpx;box-sizing:border-box;display:flex;justify-content:space-between;margin-bottom:20rpx;padding:32rpx}.scenario-left{align-items:flex-start;display:flex;flex:1;gap:24rpx}.scenario-icon{flex-shrink:0;font-size:64rpx;line-height:1}.scenario-info{flex:1}.scenario-title{color:#333;display:block;font-size:28rpx;font-weight:600;margin-bottom:8rpx}.scenario-intro{color:#888;display:block;font-size:24rpx;line-height:1.5;margin-bottom:12rpx}.scenario-diff{display:flex;gap:4rpx}.star{color:#ddd;font-size:24rpx;margin-right:4rpx}.star:last-child{margin-right:0}.star.active{color:#f59e0b}.arrow{color:#ddd;flex-shrink:0;font-size:40rpx}.script-item{align-items:center;background:#fff;border-radius:32rpx;box-sizing:border-box;display:flex;gap:24rpx;margin-bottom:16rpx;padding:28rpx 32rpx}.script-icon{flex-shrink:0;font-size:48rpx}.script-info{flex:1}.script-title{color:#333;display:block;font-size:28rpx;font-weight:600;margin-bottom:4rpx}.script-desc{color:#888;display:block;font-size:24rpx;line-height:1.4}.script-tag{background:#f5f5f5;border-radius:9999rpx;flex-shrink:0;padding:4rpx 16rpx}.tag-text{color:#666;font-size:22rpx}
.page{background:#f0f0f0;box-sizing:border-box;min-height:100vh;padding:32rpx}.pt{color:#333;display:block;font-size:32rpx;font-weight:700;margin-bottom:32rpx}.script-card{background:#fff;border-left:8rpx solid #ddd;border-radius:32rpx;box-sizing:border-box;margin-bottom:24rpx;padding:40rpx}.sc-header{align-items:center;display:flex;gap:20rpx;margin-bottom:20rpx}.sc-icon{flex-shrink:0;font-size:48rpx}.sc-title{color:#333;font-size:32rpx;font-weight:700}.sc-desc{color:#555;display:block;font-size:28rpx;line-height:1.7;margin-bottom:28rpx}.sc-example{background:#f9fafb;border-radius:24rpx;padding:28rpx}.sc-ex-label{color:#888;display:block;font-size:24rpx;margin-bottom:16rpx}.sc-ex-text{color:#333;display:block;font-size:26rpx;font-style:italic;line-height:1.7;white-space:pre-wrap}
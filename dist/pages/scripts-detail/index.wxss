.page{background:#f0f0f0;box-sizing:border-box;min-height:100vh;padding:16rpx}.pt{color:#333;display:block;font-size:16rpx;font-weight:700;margin-bottom:16rpx}.script-card{background:#fff;border-left:4rpx solid #ddd;border-radius:16rpx;margin-bottom:12rpx;padding:20rpx}.sc-header{align-items:center;display:flex;gap:10rpx;margin-bottom:10rpx}.sc-icon{flex-shrink:0;font-size:24rpx}.sc-title{color:#333;font-size:16rpx;font-weight:700}.sc-desc{color:#555;display:block;font-size:14rpx;line-height:1.7;margin-bottom:14rpx}.sc-example{background:#f9fafb;border-radius:12rpx;padding:14rpx}.sc-ex-label{color:#888;display:block;font-size:12rpx;margin-bottom:8rpx}.sc-ex-text{color:#333;display:block;font-size:13rpx;font-style:italic;line-height:1.7;white-space:pre-wrap}
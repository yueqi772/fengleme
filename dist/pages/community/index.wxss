.page{background:#f0f0f0;box-sizing:border-box;min-height:100vh;padding-bottom:40rpx}.tb{align-items:center;background:#fff;display:flex;justify-content:space-between;padding:32rpx 32rpx 24rpx}.title{color:#333;font-size:32rpx;font-weight:700}.pbtn{background:#07c160;border:none;border-radius:9999rpx;box-sizing:border-box;color:#fff;font-size:26rpx;padding:12rpx 32rpx}.tabs{background:#fff;border-bottom:2rpx solid #f0f0f0;box-sizing:border-box;display:flex;gap:16rpx;overflow-x:auto;padding:16rpx 32rpx;white-space:nowrap}.tab{background:#f5f5f5;border-radius:9999rpx;box-sizing:border-box;color:#666;flex-shrink:0;font-size:26rpx;padding:8rpx 24rpx}.tab.active{background:#07c160;color:#fff}.posts{padding:24rpx 32rpx}.pc{background:#fff;border-radius:32rpx;margin-bottom:24rpx;padding:32rpx}.ptop{align-items:center;display:flex;gap:16rpx;margin-bottom:16rpx}.pauth{color:#333;font-size:26rpx;font-weight:600}.pind{background:#f0fdf4;border-radius:9999rpx;box-sizing:border-box;color:#15803d;font-size:22rpx;padding:2rpx 12rpx}.ptime{color:#aaa;font-size:22rpx;margin-left:auto}.pcontent{color:#444;display:block;font-size:28rpx;line-height:1.6;margin-bottom:20rpx}.ptags{display:flex;flex-wrap:wrap;gap:12rpx;margin-bottom:20rpx}.ptag{background:#fef2f2;border-radius:9999rpx;box-sizing:border-box;color:#dc2626;font-size:24rpx;padding:4rpx 16rpx}.pstats{display:flex;gap:32rpx}.pstat{color:#aaa;font-size:24rpx}
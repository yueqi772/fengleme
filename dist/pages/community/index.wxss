.page{background:#f0f0f0;min-height:100vh;padding-bottom:20rpx}.tb{align-items:center;background:#fff;display:flex;justify-content:space-between;padding:16rpx 16rpx 12rpx}.title{color:#333;font-size:16rpx;font-weight:700}.pbtn{background:#07c160;border:none;border-radius:9999rpx;box-sizing:border-box;color:#fff;font-size:13rpx;padding:6rpx 16rpx}.tabs{background:#fff;border-bottom:1rpx solid #f0f0f0;box-sizing:border-box;display:flex;gap:8rpx;overflow-x:auto;padding:8rpx 16rpx;white-space:nowrap}.tab{background:#f5f5f5;border-radius:9999rpx;box-sizing:border-box;color:#666;flex-shrink:0;font-size:13rpx;padding:4rpx 12rpx}.tab.active{background:#07c160;color:#fff}.posts{padding:12rpx 16rpx}.pc{background:#fff;border-radius:16rpx;margin-bottom:12rpx;padding:16rpx}.ptop{align-items:center;display:flex;gap:8rpx;margin-bottom:8rpx}.pauth{color:#333;font-size:13rpx;font-weight:600}.pind{background:#f0fdf4;border-radius:9999rpx;box-sizing:border-box;color:#15803d;font-size:11rpx;padding:1rpx 6rpx}.ptime{color:#aaa;font-size:11rpx;margin-left:auto}.pcontent{color:#444;display:block;font-size:14rpx;line-height:1.6;margin-bottom:10rpx}.ptags{display:flex;flex-wrap:wrap;gap:6rpx;margin-bottom:10rpx}.ptag{background:#fef2f2;border-radius:9999rpx;box-sizing:border-box;color:#dc2626;font-size:12rpx;padding:2rpx 8rpx}.pstats{display:flex;gap:16rpx}.pstat{color:#aaa;font-size:12rpx}
.page{background:#f0f0f0;box-sizing:border-box;min-height:100vh;padding:32rpx 32rpx 160rpx}.post{background:#fff;border-radius:32rpx;margin-bottom:32rpx;padding:40rpx}.p-top{align-items:center;display:flex;justify-content:space-between;margin-bottom:24rpx}.p-auth{color:#333;font-size:28rpx;font-weight:600}.p-time{color:#aaa;font-size:24rpx}.p-content{color:#333;display:block;font-size:30rpx;line-height:1.7;margin-bottom:28rpx}.p-tags{display:flex;flex-wrap:wrap;gap:16rpx;margin-bottom:28rpx}.htag{background:#fef2f2;border-radius:9999rpx;box-sizing:border-box;color:#dc2626;font-size:24rpx;padding:4rpx 20rpx}.p-actions{align-items:center;border-top:2rpx solid #f5f5f5;display:flex;gap:32rpx;padding-top:24rpx}.act-btn{background:none;border:2rpx solid #e5e7eb;border-radius:9999rpx;box-sizing:border-box;color:#666;font-size:26rpx;padding:8rpx 28rpx}.act-btn.actived{background:#fef2f2;border-color:#fecaca;color:#dc2626}.act-text{color:#aaa;font-size:26rpx}.cm-title{color:#333;display:block;font-size:28rpx;font-weight:600;margin-bottom:24rpx}.cm-list{margin-bottom:32rpx}.cm-item{background:#fff;border-radius:24rpx;margin-bottom:16rpx;padding:28rpx}.cm-auth{color:#333;display:block;font-size:26rpx;font-weight:600;margin-bottom:4rpx}.cm-time{color:#aaa;display:block;font-size:22rpx;margin-bottom:12rpx}.cm-content{color:#555;display:block;font-size:28rpx;line-height:1.6}.cm-input{background:#fff;border-top:2rpx solid #eee;bottom:0;box-sizing:border-box;display:flex;gap:20rpx;left:0;padding:24rpx 32rpx;position:fixed;right:0}.inp{background:#f5f5f5;border-radius:9999rpx;flex:1;font-size:28rpx;padding:20rpx 32rpx}.snd-btn{background:#07c160;border:none;border-radius:9999rpx;box-sizing:border-box;color:#fff;font-size:28rpx;padding:20rpx 36rpx}
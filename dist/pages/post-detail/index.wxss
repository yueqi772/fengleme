.page{background:#f0f0f0;box-sizing:border-box;min-height:100vh;padding:16rpx 16rpx 80rpx}.post{background:#fff;border-radius:16rpx;margin-bottom:16rpx;padding:20rpx}.p-top{align-items:center;display:flex;justify-content:space-between;margin-bottom:12rpx}.p-auth{color:#333;font-size:14rpx;font-weight:600}.p-time{color:#aaa;font-size:12rpx}.p-content{color:#333;display:block;font-size:15rpx;line-height:1.7;margin-bottom:14rpx}.p-tags{display:flex;flex-wrap:wrap;gap:8rpx;margin-bottom:14rpx}.htag{background:#fef2f2;border-radius:9999rpx;color:#dc2626;font-size:12rpx;padding:2rpx 10rpx}.p-actions{align-items:center;border-top:1rpx solid #f5f5f5;display:flex;gap:16rpx;padding-top:12rpx}.act-btn{background:none;border:1rpx solid #e5e7eb;border-radius:9999rpx;color:#666;font-size:13rpx;padding:4rpx 14rpx}.act-btn.actived{background:#fef2f2;border-color:#fecaca;color:#dc2626}.act-text{color:#aaa;font-size:13rpx}.cm-title{color:#333;display:block;font-size:14rpx;font-weight:600;margin-bottom:12rpx}.cm-list{margin-bottom:16rpx}.cm-item{background:#fff;border-radius:12rpx;margin-bottom:8rpx;padding:14rpx}.cm-auth{color:#333;display:block;font-size:13rpx;font-weight:600;margin-bottom:2rpx}.cm-time{color:#aaa;display:block;font-size:11rpx;margin-bottom:6rpx}.cm-content{color:#555;display:block;font-size:14rpx;line-height:1.6}.cm-input{background:#fff;border-top:1rpx solid #eee;bottom:0;box-sizing:border-box;display:flex;gap:10rpx;left:0;padding:12rpx 16rpx;position:fixed;right:0}.inp{background:#f5f5f5;border-radius:9999rpx;flex:1;font-size:14rpx;padding:10rpx 16rpx}.snd-btn{background:#07c160;border:none;border-radius:9999rpx;box-sizing:border-box;color:#fff;font-size:14rpx;padding:10rpx 18rpx}
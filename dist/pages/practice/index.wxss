.page{background:#f0f0f0;box-sizing:border-box;min-height:100vh;padding:16rpx}.pt{color:#333;display:block;font-size:16rpx;font-weight:700;margin-bottom:4rpx}.pd{color:#aaa;display:block;font-size:12rpx;margin-bottom:16rpx}.si{align-items:center;background:#fff;border-radius:16rpx;display:flex;gap:12rpx;margin-bottom:10rpx;padding:16rpx}.sii{flex-shrink:0;font-size:32rpx}.sic{flex:1}.sit{color:#333;display:block;font-size:14rpx;font-weight:600;margin-bottom:4rpx}.sil{color:#888;display:block;font-size:12rpx;line-height:1.5;margin-bottom:4rpx}.sd{display:flex;gap:2rpx}.st{color:#ddd;font-size:12rpx}.st.act{color:#f59e0b}.sarr{color:#ddd;flex-shrink:0;font-size:20rpx}.chat-page{background:#f0f0f0;display:flex;flex-direction:column;min-height:100vh}.chat-hd{align-items:center;background:#fff;border-bottom:1rpx solid #eee;display:flex;justify-content:space-between;padding:12rpx 16rpx}.ch-title{color:#333;font-size:14rpx;font-weight:600}.ch-round{color:#aaa;font-size:12rpx}.msgs{flex:1;overflow-y:auto;padding:12rpx}.mr{display:flex;margin-bottom:10rpx}.mr.ur{flex-direction:row-reverse}.bub{border-radius:16rpx;box-sizing:border-box;font-size:14rpx;line-height:1.5;max-width:75%;padding:10rpx 14rpx}.bub-me{background:#07c160;border-bottom-right-radius:4rpx;color:#fff}.bub-ai{background:#fff;border-bottom-left-radius:4rpx;box-shadow:0 1rpx 4rpx rgba(0,0,0,.06);color:#333}.bt{display:block}.done-card{background:#fff;border-top:1rpx solid #eee;padding:16rpx}.dc-badge{display:block;font-size:15rpx;font-weight:700;margin-bottom:6rpx}.dc-hint{color:#888;display:block;font-size:13rpx;margin-bottom:14rpx}.dc-btn{background:#07c160;border:none;border-radius:9999rpx;box-sizing:border-box;color:#fff;font-size:14rpx;padding:12rpx;width:100%}.inp-row{background:#fff;border-top:1rpx solid #eee;display:flex;gap:10rpx;padding:12rpx 16rpx}.inp{background:#f5f5f5;border-radius:9999rpx;flex:1;font-size:14rpx;padding:10rpx 16rpx}.snd{background:#07c160;border:none;border-radius:9999rpx;color:#fff;font-size:16rpx;line-height:1;padding:10rpx 18rpx}
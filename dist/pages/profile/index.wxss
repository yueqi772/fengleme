.page{background:#f0f0f0;box-sizing:border-box;min-height:100vh;padding:32rpx}.profile-card{background:linear-gradient(135deg,#07c160,#06a356);border-radius:40rpx;margin-bottom:32rpx;padding:48rpx;text-align:center}.avatar-circle{align-items:center;background:hsla(0,0%,100%,.2);border-radius:50%;display:flex;height:128rpx;justify-content:center;margin:0 auto 24rpx;width:128rpx}.av-emoji{font-size:64rpx}.profile-name{color:#fff;display:block;font-size:36rpx;font-weight:700;margin-bottom:8rpx}.profile-days{color:hsla(0,0%,100%,.75);display:block;font-size:24rpx}.stats-row{align-items:center;background:#fff;border-radius:32rpx;display:flex;margin-bottom:32rpx;padding:32rpx}.stat-box{flex:1;text-align:center}.stat-n{color:#07c160;display:block;font-size:48rpx;font-weight:700}.stat-l{color:#aaa;display:block;font-size:22rpx;margin-top:4rpx}.stat-div{background:#eee;height:60rpx;width:2rpx}.section-title{color:#333;display:block;font-size:28rpx;font-weight:600;margin:0 0 20rpx;padding-left:8rpx}.achievements{background:#fff;border-radius:32rpx;margin-bottom:32rpx;padding:8rpx 0}.achievement-item{align-items:center;border-bottom:2rpx solid #f5f5f5;display:flex;gap:24rpx;padding:24rpx 32rpx}.achievement-item:last-child{border-bottom:none}.achi-icon{flex-shrink:0;font-size:48rpx}.achi-info{flex:1}.achi-title{color:#333;display:block;font-size:26rpx;font-weight:600;margin-bottom:4rpx}.achi-desc{color:#aaa;display:block;font-size:24rpx}.menu-list{background:#fff;border-radius:32rpx;margin-bottom:32rpx;overflow:hidden}.menu-item{align-items:center;border-bottom:2rpx solid #f5f5f5;box-sizing:border-box;display:flex;gap:24rpx;padding:28rpx 32rpx}.menu-item:last-child{border-bottom:none}.menu-icon{flex-shrink:0;font-size:40rpx}.menu-text{color:#333;flex:1;font-size:28rpx}.menu-arrow{color:#ccc;font-size:36rpx}.footer-quote{background:#f0fdf4;border-radius:32rpx;margin-top:16rpx;padding:32rpx;text-align:center}.fq{color:#166534;display:block;font-size:28rpx;font-style:italic}
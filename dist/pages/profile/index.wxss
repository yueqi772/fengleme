.page{background:#f0f0f0;min-height:100vh;padding:16rpx}.profile-card{background:linear-gradient(135deg,#07c160,#06a356);border-radius:20rpx;margin-bottom:16rpx;padding:24rpx;text-align:center}.avatar-circle{align-items:center;background:hsla(0,0%,100%,.2);border-radius:50%;display:flex;height:64rpx;justify-content:center;margin:0 auto 12rpx;width:64rpx}.av-emoji{font-size:32rpx}.profile-name{color:#fff;display:block;font-size:18rpx;font-weight:700;margin-bottom:4rpx}.profile-days{color:hsla(0,0%,100%,.75);display:block;font-size:12rpx}.stats-row{align-items:center;background:#fff;border-radius:16rpx;display:flex;margin-bottom:16rpx;padding:16rpx}.stat-box{flex:1;text-align:center}.stat-n{color:#07c160;display:block;font-size:24rpx;font-weight:700}.stat-l{color:#aaa;display:block;font-size:11rpx;margin-top:2rpx}.stat-div{background:#eee;height:30rpx;width:1rpx}.section-title{color:#333;display:block;font-size:14rpx;font-weight:600;margin:0 0 10rpx;padding-left:4rpx}.achievements{background:#fff;border-radius:16rpx;margin-bottom:16rpx;padding:4rpx 0}.achievement-item{align-items:center;border-bottom:1rpx solid #f5f5f5;display:flex;gap:12rpx;padding:12rpx 16rpx}.achievement-item:last-child{border-bottom:none}.achi-icon{flex-shrink:0;font-size:24rpx}.achi-info{flex:1}.achi-title{color:#333;display:block;font-size:13rpx;font-weight:600;margin-bottom:2rpx}.achi-desc{color:#aaa;display:block;font-size:12rpx}.menu-list{background:#fff;border-radius:16rpx;margin-bottom:16rpx;overflow:hidden}.menu-item{align-items:center;border-bottom:1rpx solid #f5f5f5;display:flex;gap:12rpx;padding:14rpx 16rpx}.menu-item:last-child{border-bottom:none}.menu-icon{flex-shrink:0;font-size:20rpx}.menu-text{color:#333;flex:1;font-size:14rpx}.menu-arrow{color:#ccc;font-size:18rpx}.footer-quote{background:#f0fdf4;border-radius:16rpx;margin-top:8rpx;padding:16rpx;text-align:center}.fq{color:#166534;display:block;font-size:14rpx;font-style:italic}
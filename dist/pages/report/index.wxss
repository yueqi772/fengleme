.page{background:#f0f0f0;box-sizing:border-box;min-height:100vh;padding:16rpx}.report-hero{border-radius:24rpx;margin-bottom:16rpx;padding:32rpx 24rpx;text-align:center}.re-emoji{display:block;font-size:40rpx;margin-bottom:8rpx}.re-score{display:block;font-size:56rpx;font-weight:800;line-height:1}.re-unit{color:rgba(0,0,0,.4);display:block;font-size:18rpx;margin-bottom:8rpx}.re-desc{display:block;font-size:14rpx}.card{background:#fff;border-radius:16rpx;margin-bottom:12rpx;padding:20rpx}.card-title{color:#333;display:block;font-size:15rpx;font-weight:700;margin-bottom:14rpx}.none-tip{color:#aaa;display:block;font-size:14rpx;padding:16rpx 0;text-align:center}.pua-item{align-items:center;border-bottom:1rpx solid #f5f5f5;display:flex;gap:10rpx;padding:10rpx 0}.pua-item:last-child{border-bottom:none}.pua-dot{color:#ef4444;flex-shrink:0;font-size:8rpx}.pua-type{color:#333;font-size:14rpx}.card-quote{background:#f0fdf4;border-radius:10rpx;color:#166534;display:block;font-size:15rpx;font-style:italic;line-height:1.7;margin-bottom:12rpx;padding:12rpx}.card-body{color:#555;display:block;font-size:13rpx;line-height:1.7}.next-item{align-items:center;border-bottom:1rpx solid #f5f5f5;display:flex;gap:12rpx;padding:10rpx 0}.next-item:last-child{border-bottom:none}.next-icon{flex-shrink:0;font-size:22rpx}.next-info{flex:1}.next-t{color:#333;display:block;font-size:14rpx;font-weight:600;margin-bottom:2rpx}.next-d{color:#888;display:block;font-size:12rpx}.home-btn{background:#07c160;border:none;border-radius:9999rpx;box-sizing:border-box;color:#fff;display:block;font-size:15rpx;font-weight:600;margin-top:8rpx;padding:14rpx;width:100%}.empty{padding:80rpx 0;text-align:center}.et{color:#333;display:block;font-size:16rpx;font-weight:600;margin-bottom:8rpx}.ed{color:#aaa;display:block;font-size:14rpx}
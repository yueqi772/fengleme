.page{background:#f0f0f0;box-sizing:border-box;min-height:100vh;padding:32rpx}.report-hero{background:linear-gradient(135deg,#07c160,#06a356);border-radius:48rpx;margin-bottom:32rpx;padding:64rpx 48rpx;text-align:center}.re-emoji{display:block;font-size:80rpx;margin-bottom:16rpx}.re-score{color:#fff;display:block;font-size:112rpx;font-weight:800;line-height:1}.re-unit{color:hsla(0,0%,100%,.6);display:block;font-size:36rpx;margin-bottom:16rpx;margin-top:8rpx}.re-desc{color:hsla(0,0%,100%,.85);display:block;font-size:28rpx}.card{background:#fff;border-radius:32rpx;margin-bottom:24rpx;padding:40rpx}.card-title{color:#333;display:block;font-size:30rpx;font-weight:700;margin-bottom:28rpx}.none-tip{color:#aaa;display:block;font-size:28rpx;padding:32rpx 0;text-align:center}.pua-item{align-items:center;border-bottom:2rpx solid #f5f5f5;display:flex;gap:20rpx;padding:20rpx 0}.pua-item:last-child{border-bottom:none}.pua-dot{color:#ef4444;flex-shrink:0;font-size:16rpx}.pua-type{color:#333;font-size:28rpx}.card-quote{background:#f0fdf4;border-radius:20rpx;box-sizing:border-box;color:#166534;display:block;font-size:30rpx;font-style:italic;line-height:1.7;margin-bottom:24rpx;padding:24rpx}.card-body{color:#555;display:block;font-size:26rpx;line-height:1.7}.next-item{align-items:center;border-bottom:2rpx solid #f5f5f5;display:flex;gap:24rpx;padding:20rpx 0}.next-item:last-child{border-bottom:none}.next-icon{flex-shrink:0;font-size:44rpx}.next-info{flex:1}.next-t{color:#333;display:block;font-size:28rpx;font-weight:600;margin-bottom:4rpx}.next-d{color:#888;display:block;font-size:24rpx}.home-btn{background:#07c160;border:none;border-radius:9999rpx;box-sizing:border-box;color:#fff;display:block;font-size:30rpx;font-weight:600;margin-top:16rpx;padding:28rpx;width:100%}.empty{padding:160rpx 0;text-align:center}.et{color:#333;display:block;font-size:32rpx;font-weight:600;margin-bottom:16rpx}.ed{color:#aaa;display:block;font-size:28rpx}